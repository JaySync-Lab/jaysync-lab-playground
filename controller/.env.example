# Copy to /etc/playground-controller/controller.env on CT 105, fill in real
# values, and chmod 600 it — Step 3.7 verification gate: "Token file
# permissions confirmed restrictive (not world-readable)".
#
# UNTESTED-PENDING-HOST: these variable names match what app/config.py
# reads, but the token itself doesn't exist yet — Step 3.3 (creating the
# Proxmox API token) is paused until the host is back online.

PROXMOX_HOST=192.168.1.100
PROXMOX_NODE=jaysync-lab
PROXMOX_TOKEN_ID=playground-ctrl@pve!api-token
PROXMOX_TOKEN_SECRET=
PROXMOX_VERIFY_SSL=false

# Placeholders — see the ASSUMPTION/open-item notes in app/config.py.
SESSION_MAX_DURATION_MINUTES=15
SESSION_GRACE_PERIOD_SECONDS=60
TTYD_HEALTHCHECK_TIMEOUT_SECONDS=30

SANDBOX_SUBNET_PREFIX=10.99.0
CONTROLLER_SANDBOX_IP=10.99.0.1
